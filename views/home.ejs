<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Página Inicial</title>
    <%-include('layout/head') %>
</head>
<body>
    <%-include('layout/menu') %>
    <div style="position: relative; width: 100%; height: 380px; overflow: hidden; border: solid 0.5px;" >
      <img src="/images/f3.jpg" style="width: 100%; height: 100%; object-fit: cover;">
      <div style="position: absolute; bottom: 20%; right: 5%; color: white; font-size: 24px; ">
          <% if (logado == true) { %>
            <br>
            <br>
            <br>
            <h1 style="text-shadow:2px 2px 0px black">Bem-vindo(a) <%= nome %>!</h1 >
            <h5 style="text-shadow:2px 2px 0px black">SafePet, o site que você precisa!</h5>
            <br>
            <a class="btn btn-dark" href="/adotar" style="width: 180px; border: solid 1px rgb(18, 18, 18);"><i style="vertical-align:bottom;" class="material-icons">pets</i> Adoção</a>
            <a class="btn btn-dark" href="" style="width: 180px; border: solid 1px rgb(18, 18, 18);"><i style="vertical-align:bottom;" class="material-icons">handshake</i> Desaparecidos</a>
          <% }else { %>
            <br>
            <br>
            <br>
            <h1 style="text-shadow:2px 2px 0px black">Seja Bem-vindo(a)!</h1>
            <h5 style="text-shadow:2px 2px 0px black">SafePet o site que você precisa!</h5>
            <br>
            <br>
            <a class="btn btn-dark" href="/login" style="width: 180px; border: solid 1px rgb(18, 18, 18);"><i style="vertical-align:bottom;" class="material-icons">login</i>&nbsp; Login</a>
            <a class="btn btn-dark" href="/cadastro" style="width: 180px; border: solid 1px rgb(18, 18, 18);"><i style="vertical-align:bottom;" class="material-icons">person_add</i>&nbsp; Cadastre-se</a>
            <% } %> 
      </div>
    </div>
    <%-include('layout/footer') %>
</body>
</html>