<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Login</title>
        <%- include('layout/head'); %>
    </head>
    <body>
        <%- include('layout/menu'); %>
        <br>
        <br>
        <br>
        <div class="container">
            <div class="container">
                <% if (alerta) { %>
                    <div class="alert alert-dark" role="alert"><%= alerta %></div>
                <%} else { %>
        
                <% } %>
                <div class="card" style="border-radius: 10px;">
                    <div class="container">
                        <br>
                        <div class="d-flex align-items-center">
                            <img src="/images/login.png" width="60px">
                            <h4 class="ml-2">Login</h4>
                        </div>
                        <br>
                        <form method="post" action="/login">
                            <div class="mb-3">
                            <label for="exampleInputEmail1" class="form-label"><h6>E-mail</h6></label>
                            <input name="email" required type="email" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp">
                            <div id="emailHelp" class="form-text">Informe seu e-mail.</div>
                            </div>
                            <div class="mb-3">
                            <label for="exampleInputPassword1" class="form-label"><h6>Senha</h6></label>
                            <input name="senha" required type="password" class="form-control" id="exampleInputPassword1">
                            <div id="passwordHelp" class="form-text">Informe sua senha.</div>
                            </div>
                            Não possui conta? <a href="/cadastro">cadastre-se!</a>
                            <br>
                            <br>
                            <button type="submit" class="btn btn-dark">Entrar</button>
                        </form>
                        <br>
                    </div>
                </div>
            </div>
        </div>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <%- include("layout/footer"); %>
    </body>
</html>